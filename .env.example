APP_NAME="RenovaSim"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL via Supabase)
# ─────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=aws-0-xx-xxxxxxxxx-x.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=your-db-password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────────
# MAIL
# ─────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@renovasim.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────
# STORAGE — AWS S3 / Supabase S3-compatible
# Bucket "avatars" digunakan untuk foto profil user
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-supabase-s3-access-key-id
AWS_SECRET_ACCESS_KEY=your-supabase-s3-secret-access-key
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=avatars
AWS_URL=https://your-project-ref.storage.supabase.co/storage/v1/object/public/avatars
AWS_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
AWS_USE_PATH_STYLE_ENDPOINT=true

# Bucket untuk thumbnail dan upload room 3D
AWS_THUMBNAILS_BUCKET=thumbnails
AWS_ROOM_UPLOADS_BUCKET=room-uploads

# ─────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=sb_publishable_your-anon-key
SUPABASE_SECRET=sb_secret_your-service-role-key

SUPABASE_THUMBNAILS_URL=https://your-project-ref.storage.supabase.co/storage/v1/object/public/thumbnails
SUPABASE_UPLOADS_URL=https://your-project-ref.storage.supabase.co/storage/v1/object/public/room-uploads

# ─────────────────────────────────────────────
# ESTIMATION API (FastAPI / Python backend)
# ─────────────────────────────────────────────
ESTIMATION_API_URL=http://localhost:8000
ESTIMATION_API_KEY=your-estimation-api-key

# ─────────────────────────────────────────────
# GROQ AI (untuk fitur estimasi berbasis LLM)
# ─────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ─────────────────────────────────────────────
# 3D EDITOR (Flask / Three.js backend)
# ─────────────────────────────────────────────
FLASK_URL=http://localhost:5000/api

VITE_APP_NAME="${APP_NAME}"
